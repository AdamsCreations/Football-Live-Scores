<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clario Live</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div id="header">
      <h1>ClarioLive</h1>
    </div>
    <div id="content">
      <div id="matches">
        <div id="matches-buttons">
          <button id="todays-matches-btn">Today's matches</button>
          <button id="fixtures-btn">Fixtures</button>
          <button id="results-btn">Results</button>
        </div>
        <div id="matches-content">
          <ul id="todays-matches"></ul>
          <div id="fixtures"></div>
          <ul id="results"></ul>
        </div>
      </div>
      <div id="competition">
        <div id="competition-buttons">
          <button id="standings-btn">Standings</button>
          <button id="top-goal-scorers">Top goal scorers</button>
        </div>
        <div id="competition-content">
          <ul id="standings"></ul>
          <%= standings %>
          <div id="top-goal-scorers"></div>
        </div>
      </div>
    </div>
    <script src="/script.js"></script>
  </body>
</html>
